<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro e Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: var(--bs-body-bg);
        }

        .form-container {
            width: 100%;
            max-width: 400px;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.4);
        }
    </style>
</head>

<body>
    <div class="form-container bg-body">
        <h4 class="mb-3">Cadastro</h4>
        <form method="post" action="/usuario/cadastrar">
            <div class="mb-3">
                <label for="registerName" class="form-label">Nome</label>
                <input type="text" name="nome" class="form-control" id="registerName" required>
            </div>
            <div class="mb-3">
                <label for="registerEmail" class="form-label">Email</label>
                <input type="email" name="email" class="form-control" id="registerEmail" required>
            </div>
            <div class="mb-3">
                <label for="registerPassword" class="form-label">Senha</label>
                <input type="password" name="senha" class="form-control" id="registerPassword" required>
            </div>
            <button type="submit" class="btn btn-success w-100">Cadastrar</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <% if (mensagem) { %>

        <script>
            Swal.fire({
                icon: '<%= mensagem.tipo %>',
                text: '<%= mensagem.valor %>'
            });
        </script>

        <% } %>
</body>

</html>